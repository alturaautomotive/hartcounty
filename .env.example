DATABASE_URL="file:./dev.db" # Local SQLite

# Supabase (Prod): postgresql://postgres.[project_ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Local: Use above or Docker Postgres; cp .env.example .env

# Email / SMTP configuration (used by nodemailer in booking notifications)
# Dev: run MailDev (npm i -g maildev && maildev) on localhost:1025 for fake SMTP
# Prod: configure real SMTP credentials below
EMAIL_FROM=shelter@hcars.org
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# Production example:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password

# PayPal (sandbox or live)
# Get credentials at https://developer.paypal.com/dashboard/applications/sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_sandbox_client_id
PAYPAL_SECRET=your_sandbox_secret

# Meta Catalog (Commerce Manager)
# catalog_id: From Business Manager > Commerce Manager > your catalog ID
# access_token: System User token with `catalog_management` permission
META_CATALOG_ID=your_catalog_id_here
META_CATALOG_ACCESS_TOKEN=your_system_user_access_token_here

# Supabase Storage (for pet/team image uploads)
# NEXT_PUBLIC_SUPABASE_URL: from Supabase Dashboard > Settings > API
# SUPABASE_SERVICE_ROLE_KEY: from Supabase Dashboard > Settings > API > service_role
#   SECRET — server-side only, never prefix with NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_URL=https://gefhduafjpktbudokszz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin Auth
ADMIN_SECRET=              # Signs HMAC admin session tokens — required

# Resend (replaces Nodemailer/SMTP)
RESEND_API_KEY=
RESEND_FROM_EMAIL=rescue@hartcountyanimalrescue.org

# Inngest (CRON scheduling)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Meta / Facebook Messenger
META_VERIFY_TOKEN=         # Any secret string you set in Meta App Dashboard
META_APP_SECRET=           # From Meta App > Settings > Basic
META_PAGE_ACCESS_TOKEN=    # From Meta App > Messenger > Page Access Token
META_PAGE_ID=              # Your Facebook Page numeric ID
